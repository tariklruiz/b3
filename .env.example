# ============================================================================
# FII Guia — Environment variables for LOCAL parser.py runs
# ----------------------------------------------------------------------------
# Copy this file to ".env" (remove the ".example" suffix) and fill in your
# actual Railway Postgres PUBLIC URL.
#
# HOW TO GET THE PUBLIC URL:
#   1. Open Railway -> b3app project -> Postgres service
#   2. Variables tab
#   3. Look for DATABASE_PUBLIC_URL (might be hidden behind the eye icon)
#   4. If it doesn't exist:
#        Settings -> Networking -> Public Networking -> "Generate TCP Proxy"
#        Then come back to Variables, DATABASE_PUBLIC_URL will be there
#   5. Copy the full URL and paste below (replacing the placeholder)
#
# IMPORTANT — DO NOT COMMIT THIS FILE
#   Your real .env contains the Postgres password. Add ".env" to .gitignore.
#   Only commit this .env.example template.
# ============================================================================

DATABASE_URL=postgresql://postgres:REPLACE_WITH_PASSWORD@REPLACE_WITH_HOST.proxy.rlwy.net:REPLACE_WITH_PORT/railway
